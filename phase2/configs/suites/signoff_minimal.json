{
  "schema": "trecap_phase2_suite_config_v1",
  "suite_name": "signoff_minimal",
  "description": "One-vector-per-required-class candidate suite. Use before signoff_full to catch contract failures quickly.",
  "lifecycle_status": "candidate_signoff",
  "signoff_ready": false,
  "contract": {
    "spec_revision": "core_rev_j",
    "tail_policy": "full_tail",
    "rounding": "round_nearest_ties_away_from_zero",
    "threshold_mapping": "raw_thr2",
    "default_protection": {
      "PROTECT_DC": 1,
      "PROTECT_NYQ": 0
    }
  },
  "default_vector_config_dir": "configs/vectors",
  "default_artifact_root": "artifacts",
  "recommended_make_targets": [
    "coeffs",
    "vectors-suite",
    "golden-suite",
    "quality-bounds",
    "freeze-release"
  ],
  "acceptance": {
    "require_canonical_memh": true,
    "require_manifest_hashes": true,
    "require_exact_row_counts": true,
    "require_json_schema_validation": true,
    "require_frame_stats_for_every_vector": true,
    "bin_stats_policy": "only_when_vector_requires_bin_stats",
    "require_quality_bounds": true,
    "require_thr2_zero_masks_for_no_suppression_vectors": true,
    "require_no_internal_overflow_flags": true
  },
  "vector_selection": [
    {
      "name": "zero_Ns4096_thr0",
      "class": "zero_input",
      "required": true,
      "requires_bin_stats": false,
      "rationale": "Required zero-input class."
    },
    {
      "name": "no_suppression_multitone_Ns4096_thr0",
      "class": "no_suppression_thr2_zero",
      "required": true,
      "requires_bin_stats": false,
      "rationale": "Required nonzero THR2=0 near-lossless baseline."
    },
    {
      "name": "impulse_Ns1024_thr0",
      "class": "impulse",
      "required": true,
      "requires_bin_stats": false,
      "rationale": "Required impulse startup/flush/delay class."
    },
    {
      "name": "step_Ns1024_thr0",
      "class": "step",
      "required": true,
      "requires_bin_stats": false,
      "rationale": "Required step startup/flush/delay class."
    },
    {
      "name": "exact_bin_cosine_k16_Ns4096_thr0",
      "class": "exact_bin_tone",
      "required": true,
      "requires_bin_stats": false,
      "rationale": "Required exact-bin tone placement class."
    },
    {
      "name": "off_bin_sine_35_over_512_Ns4096_thr0",
      "class": "off_bin_tone",
      "required": true,
      "requires_bin_stats": false,
      "rationale": "Required leakage/off-bin class."
    },
    {
      "name": "near_threshold_multitone_Ns1024_thr64",
      "class": "near_threshold_multitone",
      "required": true,
      "requires_bin_stats": true,
      "rationale": "Required full-precision threshold decision class."
    },
    {
      "name": "noise_xorshift32_Ns4096_thr4096",
      "class": "noise_only_stream",
      "required": true,
      "requires_bin_stats": false,
      "rationale": "Required noise-only suppression/error characterization class."
    },
    {
      "name": "high_amplitude_headroom_Ns4096_thr0",
      "class": "high_amplitude_headroom",
      "required": true,
      "requires_bin_stats": false,
      "rationale": "Required internal headroom/no-wrap class."
    },
    {
      "name": "short_impulse_Ns17_thr0",
      "class": "short_finite_stream",
      "required": true,
      "requires_bin_stats": true,
      "rationale": "Required short finite-stream/full-tail class."
    }
  ],
  "required_class_coverage": [
    "zero_input",
    "no_suppression_thr2_zero",
    "impulse",
    "step",
    "exact_bin_tone",
    "off_bin_tone",
    "near_threshold_multitone",
    "noise_only_stream",
    "high_amplitude_headroom",
    "short_finite_stream"
  ],
  "notes": [
    "Marked candidate until quality_bounds.json is regenerated and frozen from this exact suite."
  ]
}
