# SPDX-License-Identifier: MIT
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100
indent_style = space
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false
max_line_length = off

[*.{json,jsonc,yml,yaml,toml}]
indent_style = space
indent_size = 2

[*.{sv,svh,v,vh}]
indent_style = space
indent_size = 4

[*.{cpp,hpp,h,cc,cxx}]
indent_style = space
indent_size = 4

[*.py]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
indent_size = 4

[*.memh]
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = off

[*.csv]
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = off
