{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trecap.local/schemas/frozen_release_manifest.schema.json",
  "title": "T-RECAP Frozen Release Manifest Schema",
  "description": "Schema for artifacts/manifests/frozen_release_manifest.json. This is the top-level signoff manifest tying schemas, generator versions, canonical artifacts, and acceptance checks into one release record.",
  "type": "object",
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "Lowercase 64-hex-character SHA-256 digest of the canonical serialization."
    },
    "decimal_string": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)$",
      "description": "Unsigned arbitrary-precision integer encoded as a base-10 string."
    },
    "signed_decimal_string": {
      "type": "string",
      "pattern": "^-?(0|[1-9][0-9]*)$",
      "description": "Signed arbitrary-precision integer encoded as a base-10 string."
    },
    "decimal_value_string": {
      "type": "string",
      "pattern": "^-?(0|[1-9][0-9]*)(\\.[0-9]+)?$",
      "description": "Exact decimal textual value. Used for generator phases before exact decimal parsing."
    },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "^(?:/|[A-Za-z]:|.*(?:^|/)\\.\\.(?:/|$))"
      },
      "description": "Repository-relative path. Absolute paths and parent-directory traversal are forbidden."
    },
    "vector_name": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_\\-]*$",
      "minLength": 1,
      "maxLength": 96
    },
    "uint01": {
      "type": "integer",
      "enum": [
        0,
        1
      ]
    },
    "positive_int": {
      "type": "integer",
      "minimum": 1
    },
    "nonnegative_int": {
      "type": "integer",
      "minimum": 0
    },
    "signed_sample_12": {
      "type": "integer",
      "minimum": -2048,
      "maximum": 2047
    },
    "unsigned_56_decimal_string": {
      "allOf": [
        {
          "$ref": "#/$defs/decimal_string"
        }
      ],
      "description": "Unsigned W_mag2=56 threshold value. Semantic range: 0 <= THR2 < 2^56. Enforce the numeric upper bound in code after decimal-string parsing."
    },
    "rounding_mode": {
      "type": "string",
      "const": "round_nearest_ties_away_from_zero"
    },
    "tail_policy": {
      "type": "string",
      "enum": [
        "full_tail",
        "fixed_delay_truncate"
      ]
    },
    "fft_mode": {
      "type": "string",
      "enum": [
        "custom_radix2_dit_bitrev_in_natural_out",
        "vendor_fft_ip_documented"
      ]
    },
    "memh_encoding": {
      "type": "string",
      "const": "fixed_width_lowercase_hex_lf"
    },
    "hash_rule": {
      "type": "string",
      "const": "logical_integer_vector_fixed_width_hex_lf"
    },
    "threshold_mapping": {
      "type": "string",
      "enum": [
        "raw_thr2",
        "amplitude_squared_wrapper_declared",
        "switch_preset_declared"
      ]
    },
    "baseline_configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "N",
        "L",
        "P",
        "H",
        "F",
        "G",
        "D",
        "THR2",
        "PROTECT_DC",
        "PROTECT_NYQ"
      ],
      "properties": {
        "N": {
          "type": "integer",
          "const": 12
        },
        "L": {
          "type": "integer",
          "const": 256
        },
        "P": {
          "type": "integer",
          "const": 8
        },
        "H": {
          "type": "integer",
          "const": 128
        },
        "F": {
          "type": "integer",
          "const": 15
        },
        "G": {
          "type": "integer",
          "const": 128
        },
        "D": {
          "type": "integer",
          "const": 384
        },
        "THR2": {
          "$ref": "#/$defs/unsigned_56_decimal_string"
        },
        "PROTECT_DC": {
          "$ref": "#/$defs/uint01"
        },
        "PROTECT_NYQ": {
          "$ref": "#/$defs/uint01"
        }
      }
    },
    "run_configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "N",
        "L",
        "P",
        "H",
        "F",
        "G",
        "D",
        "Ns",
        "Ny",
        "frames",
        "THR2",
        "PROTECT_DC",
        "PROTECT_NYQ"
      ],
      "properties": {
        "N": {
          "type": "integer",
          "const": 12
        },
        "L": {
          "type": "integer",
          "const": 256
        },
        "P": {
          "type": "integer",
          "const": 8
        },
        "H": {
          "type": "integer",
          "const": 128
        },
        "F": {
          "type": "integer",
          "const": 15
        },
        "G": {
          "type": "integer",
          "const": 128
        },
        "D": {
          "type": "integer",
          "const": 384
        },
        "Ns": {
          "type": "integer",
          "minimum": 1
        },
        "Ny": {
          "type": "integer",
          "minimum": 1
        },
        "frames": {
          "type": "integer",
          "minimum": 1
        },
        "THR2": {
          "$ref": "#/$defs/unsigned_56_decimal_string"
        },
        "PROTECT_DC": {
          "$ref": "#/$defs/uint01"
        },
        "PROTECT_NYQ": {
          "$ref": "#/$defs/uint01"
        }
      }
    },
    "widths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "W_Qw",
        "W_tw",
        "W_u",
        "W_fft",
        "W_fft_pre",
        "W_can_pre",
        "W_can",
        "W_mag2",
        "W_ifft",
        "W_z",
        "W_ola"
      ],
      "properties": {
        "W_Qw": {
          "type": "integer",
          "const": 16
        },
        "W_tw": {
          "type": "integer",
          "const": 17
        },
        "W_u": {
          "type": "integer",
          "const": 27
        },
        "W_fft": {
          "type": "integer",
          "const": 28
        },
        "W_fft_pre": {
          "type": "integer",
          "const": 29
        },
        "W_can_pre": {
          "type": "integer",
          "const": 29
        },
        "W_can": {
          "type": "integer",
          "const": 28
        },
        "W_mag2": {
          "type": "integer",
          "const": 56
        },
        "W_ifft": {
          "type": "integer",
          "const": 36
        },
        "W_z": {
          "type": "integer",
          "const": 36
        },
        "W_ola": {
          "type": "integer",
          "const": 37
        }
      }
    },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fft_mode",
        "rounding_mode",
        "tail_policy",
        "threshold_mapping"
      ],
      "properties": {
        "fft_mode": {
          "$ref": "#/$defs/fft_mode"
        },
        "rounding_mode": {
          "$ref": "#/$defs/rounding_mode"
        },
        "tail_policy": {
          "$ref": "#/$defs/tail_policy"
        },
        "threshold_mapping": {
          "$ref": "#/$defs/threshold_mapping"
        },
        "memh_encoding": {
          "$ref": "#/$defs/memh_encoding"
        },
        "hash_rule": {
          "$ref": "#/$defs/hash_rule"
        }
      }
    },
    "coefficient_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "window_qw_sha256",
        "twiddle_re_sha256",
        "twiddle_im_sha256",
        "twiddle_inv_re_sha256",
        "twiddle_inv_im_sha256"
      ],
      "properties": {
        "window_qw_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "twiddle_re_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "twiddle_im_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "twiddle_inv_re_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "twiddle_inv_im_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "stream_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x_in_sha256",
        "y_out_sha256"
      ],
      "properties": {
        "x_in_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "y_out_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "artifact_rows": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "window_qw",
        "twiddle_re",
        "twiddle_im",
        "twiddle_inv_re",
        "twiddle_inv_im",
        "x_in",
        "y_out",
        "frame_stats_data_rows"
      ],
      "properties": {
        "window_qw": {
          "type": "integer",
          "const": 256
        },
        "twiddle_re": {
          "type": "integer",
          "const": 256
        },
        "twiddle_im": {
          "type": "integer",
          "const": 256
        },
        "twiddle_inv_re": {
          "type": "integer",
          "const": 256
        },
        "twiddle_inv_im": {
          "type": "integer",
          "const": 256
        },
        "x_in": {
          "type": "integer",
          "minimum": 1
        },
        "y_out": {
          "type": "integer",
          "minimum": 1
        },
        "frame_stats_data_rows": {
          "type": "integer",
          "minimum": 1
        },
        "bin_stats_data_rows": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "artifact_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "role",
        "artifact_type",
        "sha256",
        "canonicalized",
        "required"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/relative_path"
        },
        "role": {
          "type": "string",
          "enum": [
            "coefficient",
            "test_vector_input",
            "golden_output",
            "configuration",
            "statistics",
            "manifest",
            "debug",
            "release_package"
          ]
        },
        "artifact_type": {
          "type": "string",
          "enum": [
            "memh",
            "json",
            "csv",
            "md",
            "bin",
            "tar",
            "zip"
          ]
        },
        "width_bits": {
          "type": "integer",
          "minimum": 1
        },
        "signed": {
          "type": "boolean"
        },
        "rows": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "canonical_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "canonicalized": {
          "type": "boolean"
        },
        "required": {
          "type": "boolean"
        },
        "vector_name": {
          "$ref": "#/$defs/vector_name"
        },
        "schema_ref": {
          "type": "string",
          "minLength": 1
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "content_contract": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "artifact_type": {
                "const": "memh"
              }
            },
            "required": [
              "artifact_type"
            ]
          },
          "then": {
            "required": [
              "width_bits",
              "signed",
              "rows",
              "canonical_sha256"
            ]
          }
        }
      ]
    }
  },
  "additionalProperties": false,
  "required": [
    "schema",
    "release_name",
    "release_version",
    "spec_revision",
    "created_utc",
    "generator_versions",
    "manifest_hashes",
    "artifacts",
    "acceptance"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "trecap_phase2_frozen_release_manifest_v1"
    },
    "release_name": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.\\-]*$"
    },
    "release_version": {
      "type": "string",
      "pattern": "^v?[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9_.-]+)?$"
    },
    "spec_revision": {
      "type": "string",
      "const": "core_rev_j"
    },
    "telemetry_revision": {
      "type": "string",
      "const": "telemetry_rev_g"
    },
    "created_utc": {
      "type": "string",
      "format": "date-time"
    },
    "source_control": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "git_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{7,40}$"
        },
        "git_dirty": {
          "type": "boolean"
        },
        "repo_url": {
          "type": "string"
        }
      }
    },
    "generator_versions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "golden_model",
        "coefficient_generator",
        "vector_generator",
        "artifact_checker"
      ],
      "properties": {
        "golden_model": {
          "type": "string",
          "minLength": 1
        },
        "coefficient_generator": {
          "type": "string",
          "minLength": 1
        },
        "vector_generator": {
          "type": "string",
          "minLength": 1
        },
        "artifact_checker": {
          "type": "string",
          "minLength": 1
        },
        "quality_bounds_generator": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "manifest_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "core_config_sha256",
        "coeff_manifest_sha256",
        "test_vectors_sha256",
        "quality_bounds_sha256",
        "artifact_index_sha256"
      ],
      "properties": {
        "core_config_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "coeff_manifest_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "test_vectors_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "quality_bounds_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "artifact_index_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact_entry"
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "coefficients_hash_match",
        "stream_hashes_match",
        "row_counts_match",
        "json_schemas_pass",
        "csv_schemas_pass",
        "quality_bounds_pass",
        "no_internal_overflow_flags"
      ],
      "properties": {
        "coefficients_hash_match": {
          "type": "boolean",
          "const": true
        },
        "stream_hashes_match": {
          "type": "boolean",
          "const": true
        },
        "row_counts_match": {
          "type": "boolean",
          "const": true
        },
        "json_schemas_pass": {
          "type": "boolean",
          "const": true
        },
        "csv_schemas_pass": {
          "type": "boolean",
          "const": true
        },
        "quality_bounds_pass": {
          "type": "boolean",
          "const": true
        },
        "no_internal_overflow_flags": {
          "type": "boolean",
          "const": true
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "reproduction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "host_os": {
          "type": "string"
        },
        "python_version": {
          "type": "string"
        },
        "compiler_id": {
          "type": "string"
        },
        "compiler_version": {
          "type": "string"
        }
      }
    }
  }
}
