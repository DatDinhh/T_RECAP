{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trecap.local/schemas/core_config.schema.json",
  "title": "T-RECAP Phase 2 Core Config Schema",
  "description": "Schema for spec/generated/core_config.json, the golden-model source-of-truth for baseline core constants, widths, arithmetic contracts, and artifact row-count names.",
  "type": "object",
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "Lowercase 64-hex-character SHA-256 digest of the canonical serialization."
    },
    "decimal_string": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)$",
      "description": "Unsigned arbitrary-precision integer encoded as a base-10 string."
    },
    "signed_decimal_string": {
      "type": "string",
      "pattern": "^-?(0|[1-9][0-9]*)$",
      "description": "Signed arbitrary-precision integer encoded as a base-10 string."
    },
    "decimal_value_string": {
      "type": "string",
      "pattern": "^-?(0|[1-9][0-9]*)(\\.[0-9]+)?$",
      "description": "Exact decimal textual value. Used for generator phases before exact decimal parsing."
    },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "^(?:/|[A-Za-z]:|.*(?:^|/)\\.\\.(?:/|$))"
      },
      "description": "Repository-relative path. Absolute paths and parent-directory traversal are forbidden."
    },
    "vector_name": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_\\-]*$",
      "minLength": 1,
      "maxLength": 96
    },
    "uint01": {
      "type": "integer",
      "enum": [
        0,
        1
      ]
    },
    "positive_int": {
      "type": "integer",
      "minimum": 1
    },
    "nonnegative_int": {
      "type": "integer",
      "minimum": 0
    },
    "signed_sample_12": {
      "type": "integer",
      "minimum": -2048,
      "maximum": 2047
    },
    "unsigned_56_decimal_string": {
      "allOf": [
        {
          "$ref": "#/$defs/decimal_string"
        }
      ],
      "description": "Unsigned W_mag2=56 threshold value. Semantic range: 0 <= THR2 < 2^56. Enforce the numeric upper bound in code after decimal-string parsing."
    },
    "rounding_mode": {
      "type": "string",
      "const": "round_nearest_ties_away_from_zero"
    },
    "tail_policy": {
      "type": "string",
      "enum": [
        "full_tail",
        "fixed_delay_truncate"
      ]
    },
    "fft_mode": {
      "type": "string",
      "enum": [
        "custom_radix2_dit_bitrev_in_natural_out",
        "vendor_fft_ip_documented"
      ]
    },
    "memh_encoding": {
      "type": "string",
      "const": "fixed_width_lowercase_hex_lf"
    },
    "hash_rule": {
      "type": "string",
      "const": "logical_integer_vector_fixed_width_hex_lf"
    },
    "threshold_mapping": {
      "type": "string",
      "enum": [
        "raw_thr2",
        "amplitude_squared_wrapper_declared",
        "switch_preset_declared"
      ]
    },
    "baseline_configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "N",
        "L",
        "P",
        "H",
        "F",
        "G",
        "D",
        "THR2",
        "PROTECT_DC",
        "PROTECT_NYQ"
      ],
      "properties": {
        "N": {
          "type": "integer",
          "const": 12
        },
        "L": {
          "type": "integer",
          "const": 256
        },
        "P": {
          "type": "integer",
          "const": 8
        },
        "H": {
          "type": "integer",
          "const": 128
        },
        "F": {
          "type": "integer",
          "const": 15
        },
        "G": {
          "type": "integer",
          "const": 128
        },
        "D": {
          "type": "integer",
          "const": 384
        },
        "THR2": {
          "$ref": "#/$defs/unsigned_56_decimal_string"
        },
        "PROTECT_DC": {
          "$ref": "#/$defs/uint01"
        },
        "PROTECT_NYQ": {
          "$ref": "#/$defs/uint01"
        }
      }
    },
    "run_configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "N",
        "L",
        "P",
        "H",
        "F",
        "G",
        "D",
        "Ns",
        "Ny",
        "frames",
        "THR2",
        "PROTECT_DC",
        "PROTECT_NYQ"
      ],
      "properties": {
        "N": {
          "type": "integer",
          "const": 12
        },
        "L": {
          "type": "integer",
          "const": 256
        },
        "P": {
          "type": "integer",
          "const": 8
        },
        "H": {
          "type": "integer",
          "const": 128
        },
        "F": {
          "type": "integer",
          "const": 15
        },
        "G": {
          "type": "integer",
          "const": 128
        },
        "D": {
          "type": "integer",
          "const": 384
        },
        "Ns": {
          "type": "integer",
          "minimum": 1
        },
        "Ny": {
          "type": "integer",
          "minimum": 1
        },
        "frames": {
          "type": "integer",
          "minimum": 1
        },
        "THR2": {
          "$ref": "#/$defs/unsigned_56_decimal_string"
        },
        "PROTECT_DC": {
          "$ref": "#/$defs/uint01"
        },
        "PROTECT_NYQ": {
          "$ref": "#/$defs/uint01"
        }
      }
    },
    "widths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "W_Qw",
        "W_tw",
        "W_u",
        "W_fft",
        "W_fft_pre",
        "W_can_pre",
        "W_can",
        "W_mag2",
        "W_ifft",
        "W_z",
        "W_ola"
      ],
      "properties": {
        "W_Qw": {
          "type": "integer",
          "const": 16
        },
        "W_tw": {
          "type": "integer",
          "const": 17
        },
        "W_u": {
          "type": "integer",
          "const": 27
        },
        "W_fft": {
          "type": "integer",
          "const": 28
        },
        "W_fft_pre": {
          "type": "integer",
          "const": 29
        },
        "W_can_pre": {
          "type": "integer",
          "const": 29
        },
        "W_can": {
          "type": "integer",
          "const": 28
        },
        "W_mag2": {
          "type": "integer",
          "const": 56
        },
        "W_ifft": {
          "type": "integer",
          "const": 36
        },
        "W_z": {
          "type": "integer",
          "const": 36
        },
        "W_ola": {
          "type": "integer",
          "const": 37
        }
      }
    },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fft_mode",
        "rounding_mode",
        "tail_policy",
        "threshold_mapping"
      ],
      "properties": {
        "fft_mode": {
          "$ref": "#/$defs/fft_mode"
        },
        "rounding_mode": {
          "$ref": "#/$defs/rounding_mode"
        },
        "tail_policy": {
          "$ref": "#/$defs/tail_policy"
        },
        "threshold_mapping": {
          "$ref": "#/$defs/threshold_mapping"
        },
        "memh_encoding": {
          "$ref": "#/$defs/memh_encoding"
        },
        "hash_rule": {
          "$ref": "#/$defs/hash_rule"
        }
      }
    },
    "coefficient_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "window_qw_sha256",
        "twiddle_re_sha256",
        "twiddle_im_sha256",
        "twiddle_inv_re_sha256",
        "twiddle_inv_im_sha256"
      ],
      "properties": {
        "window_qw_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "twiddle_re_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "twiddle_im_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "twiddle_inv_re_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "twiddle_inv_im_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "stream_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x_in_sha256",
        "y_out_sha256"
      ],
      "properties": {
        "x_in_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "y_out_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "artifact_rows": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "window_qw",
        "twiddle_re",
        "twiddle_im",
        "twiddle_inv_re",
        "twiddle_inv_im",
        "x_in",
        "y_out",
        "frame_stats_data_rows"
      ],
      "properties": {
        "window_qw": {
          "type": "integer",
          "const": 256
        },
        "twiddle_re": {
          "type": "integer",
          "const": 256
        },
        "twiddle_im": {
          "type": "integer",
          "const": 256
        },
        "twiddle_inv_re": {
          "type": "integer",
          "const": 256
        },
        "twiddle_inv_im": {
          "type": "integer",
          "const": 256
        },
        "x_in": {
          "type": "integer",
          "minimum": 1
        },
        "y_out": {
          "type": "integer",
          "minimum": 1
        },
        "frame_stats_data_rows": {
          "type": "integer",
          "minimum": 1
        },
        "bin_stats_data_rows": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "artifact_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "role",
        "artifact_type",
        "sha256",
        "canonicalized",
        "required"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/relative_path"
        },
        "role": {
          "type": "string",
          "enum": [
            "coefficient",
            "test_vector_input",
            "golden_output",
            "configuration",
            "statistics",
            "manifest",
            "debug",
            "release_package"
          ]
        },
        "artifact_type": {
          "type": "string",
          "enum": [
            "memh",
            "json",
            "csv",
            "md",
            "bin",
            "tar",
            "zip"
          ]
        },
        "width_bits": {
          "type": "integer",
          "minimum": 1
        },
        "signed": {
          "type": "boolean"
        },
        "rows": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "canonical_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "canonicalized": {
          "type": "boolean"
        },
        "required": {
          "type": "boolean"
        },
        "vector_name": {
          "$ref": "#/$defs/vector_name"
        },
        "schema_ref": {
          "type": "string",
          "minLength": 1
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "content_contract": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "artifact_type": {
                "const": "memh"
              }
            },
            "required": [
              "artifact_type"
            ]
          },
          "then": {
            "required": [
              "width_bits",
              "signed",
              "rows",
              "canonical_sha256"
            ]
          }
        }
      ]
    }
  },
  "additionalProperties": false,
  "required": [
    "schema",
    "spec_revision",
    "configuration",
    "contract",
    "widths",
    "artifact_contract"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "trecap_phase2_core_config_v1"
    },
    "spec_revision": {
      "type": "string",
      "const": "core_rev_j"
    },
    "telemetry_revision": {
      "type": "string",
      "const": "telemetry_rev_g"
    },
    "configuration": {
      "$ref": "#/$defs/baseline_configuration"
    },
    "contract": {
      "$ref": "#/$defs/contract"
    },
    "widths": {
      "$ref": "#/$defs/widths"
    },
    "artifact_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "memh_encoding",
        "hash_rule",
        "coefficient_rows",
        "stream_file_names",
        "statistics_file_names",
        "manifest_file_names"
      ],
      "properties": {
        "memh_encoding": {
          "$ref": "#/$defs/memh_encoding"
        },
        "hash_rule": {
          "$ref": "#/$defs/hash_rule"
        },
        "coefficient_rows": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "window_qw",
            "twiddle_re",
            "twiddle_im",
            "twiddle_inv_re",
            "twiddle_inv_im"
          ],
          "properties": {
            "window_qw": {
              "type": "integer",
              "const": 256
            },
            "twiddle_re": {
              "type": "integer",
              "const": 256
            },
            "twiddle_im": {
              "type": "integer",
              "const": 256
            },
            "twiddle_inv_re": {
              "type": "integer",
              "const": 256
            },
            "twiddle_inv_im": {
              "type": "integer",
              "const": 256
            }
          }
        },
        "stream_file_names": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "x_in",
            "y_out"
          ],
          "properties": {
            "x_in": {
              "type": "string",
              "const": "x_in.memh"
            },
            "y_out": {
              "type": "string",
              "const": "y_out.memh"
            }
          }
        },
        "statistics_file_names": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "frame_stats",
            "metrics"
          ],
          "properties": {
            "frame_stats": {
              "type": "string",
              "const": "frame_stats.csv"
            },
            "metrics": {
              "type": "string",
              "const": "metrics.json"
            },
            "bin_stats": {
              "type": "string",
              "const": "bin_stats.csv"
            }
          }
        },
        "manifest_file_names": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "coeff_manifest",
            "test_vectors",
            "quality_bounds",
            "artifact_index",
            "frozen_release_manifest"
          ],
          "properties": {
            "coeff_manifest": {
              "type": "string",
              "const": "coeff_manifest.json"
            },
            "test_vectors": {
              "type": "string",
              "const": "test_vectors.json"
            },
            "quality_bounds": {
              "type": "string",
              "const": "quality_bounds.json"
            },
            "artifact_index": {
              "type": "string",
              "const": "artifact_index.json"
            },
            "frozen_release_manifest": {
              "type": "string",
              "const": "frozen_release_manifest.json"
            }
          }
        }
      }
    },
    "source_modes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bram_replay": {
          "type": "integer",
          "const": 0
        },
        "adc_live": {
          "type": "integer",
          "const": 1
        },
        "audio_wrapper": {
          "type": "integer",
          "const": 2
        },
        "diagnostic_source": {
          "type": "integer",
          "const": 3
        }
      }
    }
  }
}
